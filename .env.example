HYPERSPELL_API_KEY=your_api_key_here

# Langfuse observability (optional — leave blank to disable tracing)
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# Flask session (generate with: python3 -c "import secrets; print(secrets.token_urlsafe(48))")
FLASK_SECRET_KEY=

# Keycloak OIDC
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=pharma-poc
KEYCLOAK_CLIENT_ID=flask-app
KEYCLOAK_CLIENT_SECRET=flask-app-secret-change-me
